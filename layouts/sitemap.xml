{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{/* Hugo's embedded sitemap template, minus the multilingual block (single-
     language site) and minus noindexed pages: submitting a URL whose page
     carries a robots noindex meta is a Search Console error, and Hugo's
     default template knows nothing about baseof's noindex rule. */}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{ range .Data.Pages }}
  {{- if and .Permalink (not (partial "is-noindexed.html" .)) }}
  <url>
    <loc>{{ .Permalink }}</loc>{{ if not .Lastmod.IsZero }}
    <lastmod>{{ safeHTML (.Lastmod.Format "2006-01-02T15:04:05-07:00") }}</lastmod>{{ end }}
  </url>
  {{- end }}
  {{- end }}
</urlset>
